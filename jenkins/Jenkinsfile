pipeline {
    agent any

    stages {
        stage('Build & Push') {
            steps {
                sh 'docker build -t dhruv52991/hello-dhruv-app:${BUILD_NUMBER} ./app'
                sh 'docker push dhruv52991/hello-dhruv-app:${BUILD_NUMBER}'
            }
        }

        stage('Deploy') {
            steps {
                sh 'kubectl --kubeconfig=/var/jenkins_home/.kube/config set image deployment/hello-dhruv-deployment hello-dhruv-container=dhruv52991/hello-dhruv-app:${BUILD_NUMBER} --record'
                sh 'kubectl --kubeconfig=/var/jenkins_home/.kube/config rollout status deployment/hello-dhruv-deployment'
            }
        }
    }
}

